# Frontend Production Environment Variables
# Upload these exactly as they are to your Vercel Environment Variables settings

# Enforces the frontend to connect to the live Django database instead of using local mock data
VITE_USE_DJANGO_API=true

# The URL of your live backend (Replace with your actual backend URL once deployed, e.g. Render/Heroku)
VITE_API_BASE_URL=https://your-live-backend-url.com/api/v1
